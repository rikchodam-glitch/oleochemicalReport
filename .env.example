APP_NAME="UGC Maker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# PENTING: harus "public" agar Storage::disk('public') berfungsi dengan benar.
# Setelah setup jalankan: php artisan storage:link
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- CREA AI ---
# Digunakan oleh GenerateCharacterImageJob untuk membuat gambar karakter.
CREA_AI_API_KEY=
CREA_AI_BASE_URL=https://api.crea.ai/v1

# --- FLOW ---
# Digunakan oleh FlowService untuk orkestrasi pipeline lanjutan.
FLOW_API_KEY=
FLOW_BASE_URL=https://api.flow.ai/v1

# --- FFMPEG ---
# Jika sudah ada di PATH sistem cukup tulis: ffmpeg dan ffprobe
# Contoh Linux : /usr/bin/ffmpeg | macOS : /opt/homebrew/bin/ffmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- GEMINI (V2) ---
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# --- DEEPSEEK (V2) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# --- GROQ (V2) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

VITE_APP_NAME="${APP_NAME}"
